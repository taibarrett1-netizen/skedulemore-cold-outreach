# Dependencies
node_modules/

# Environment and secrets
.env
.env.local
.env.*.local

# Database (local state; don't commit)
database/*.db
database/*.db-journal

# Persistent browser session (cookies; don't commit)
.browser-profile/
.cold_dm_client_id

# Admin Cold Outreach Lab (session + CSV output)
admin_lab/.sessions/
admin_lab/.out/

# Logs
logs/*.log

# Follow-up debug screenshots (may contain DMs)
follow-up-screenshots/
follow-up-screenshots-download/

# Lead list (often contains real data; keep only on server or add to .env)
leads.csv

# OS and editor
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Optional: uncomment if you want to track an example lead list
# !leads.csv.example
