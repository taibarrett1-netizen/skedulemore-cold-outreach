{
  "name": "cold-dm-bot",
  "version": "1.0.0",
  "description": "Instagram cold DM automation with CSV leads, scheduling, and SQLite tracking",
  "main": "cli.js",
  "scripts": {
    "start": "node cli.js --start",
    "status": "node cli.js --status",
    "reset-daily": "node cli.js --reset-daily",
    "dashboard": "node server.js",
    "download-follow-up-screenshots": "node scripts/download-follow-up-screenshots.js",
    "clean-follow-up-screenshots": "node -e \"const fs=require('fs'),p=require('path');const d=p.join('follow-up-screenshots');if(fs.existsSync(d))for(const f of fs.readdirSync(d))if(f.endsWith('.png'))fs.unlinkSync(p.join(d,f));console.log('cleared follow-up-screenshots/*.png');\""
  },
  "keywords": [
    "instagram",
    "dm",
    "automation",
    "puppeteer"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "better-sqlite3": "^12.6.2",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "puppeteer": "^24.37.2",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
