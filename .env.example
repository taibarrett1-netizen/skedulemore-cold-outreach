# Instagram account (use a test account first)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Safety limits
DAILY_SEND_LIMIT=100
MIN_DELAY_MINUTES=5
MAX_DELAY_MINUTES=30
MAX_SENDS_PER_HOUR=20

# Run browser in background (true) or visible (false)
HEADLESS_MODE=true

# Linux VPS: when HEADLESS_MODE=false, Chromium needs a display (e.g. Xvfb). Example: DISPLAY=:99
# DISPLAY=:99

# Desktop Chrome viewport for Instagram Web (voice + DM layout). Default 1920x1200.
# Xvfb must be at least viewport + window padding (see DESKTOP_WINDOW_PAD_*), e.g. 1920x1440x24.
# DESKTOP_VIEWPORT_WIDTH=1920
# DESKTOP_VIEWPORT_HEIGHT=1200
# Extra pixels on --window-size beyond viewport (browser tabs/toolbar). Default +0,+220.
# DESKTOP_WINDOW_PAD_X=0
# DESKTOP_WINDOW_PAD_Y=280
# Headed Chromium top-left on X11 (stops WM cascade placing window off top). Format: x,y
# CHROME_WINDOW_POSITION=0,0

# Voice notes: pipe-source (preferred) or null-sink. PM2 needs PULSE_SERVER — add to .env:
# PULSE_SERVER=unix:/run/user/0/pulse/native
# XDG_RUNTIME_DIR=/run/user/0
# If module-pipe-source fails ("Module initialization failed"), set VOICE_USE_NULL_SINK=true to use null-sink+monitor instead
# VOICE_USE_NULL_SINK=true

# Slow down Puppeteer for debugging (ms). Useful with VNC. Example: 80
# PUPPETEER_SLOW_MO_MS=80

# Debug: POST /api/debug/follow-up/browser — auto-close that Chromium after N ms (else stays until PM2 restart)
# FOLLOW_UP_DEBUG_BROWSER_MS=1800000

# After voice Send, wait until thread DOM updates. Default off (false negatives common). Enable with:
# VOICE_NOTE_STRICT_VERIFY=true

# Chrome fake-mic voice: pad WAV (seconds), recording lag vs file length, loop trim (tune if clip cuts off or loops at end)
# VOICE_FAKE_MIC_PAD_START_SEC=0.12
# VOICE_FAKE_MIC_PAD_END_SEC=0.22
# VOICE_FAKE_MIC_RECORDING_LAG_MS=680
# VOICE_FAKE_MIC_HOLD_JITTER_MS=80
# VOICE_FAKE_MIC_LOOP_TRIM_MS=2200
# After voice Send (follow-ups), keep browser open N ms so IG can finish upload (default 10000). 0 = no extra wait.
# VOICE_POST_SEND_BROWSER_WAIT_MS=10000

# Log when GraphQL item_ids are captured for POST /api/follow-up/send (dashboard dedupe)
# FOLLOW_UP_MESSAGE_ID_DEBUG=1

# Headless: screenshots show recording UI but heuristics fail — still run ffmpeg + hold + Send after mic attempts.
# VOICE_ASSUME_RECORDING_AFTER_MIC=true
# Polls required to confirm recording UI (default 2). Try 1 if detection is too strict.
# VOICE_RECORDING_UI_CONFIRM_STREAK=1
# Desktop mic: run only one method (exact name). See VOICE_DESKTOP_MIC_METHOD_NAMES in instagram-voice-note.js exports.
# VOICE_DESKTOP_MIC_METHOD=mouse_hold_to_start_recording
# Send click: nudge X px right before Puppeteer mouse click (default 14). Set 0 for no offset.
# VOICE_SEND_CLICK_NUDGE_X=14
# Ms to wait after last mic attempt, then one poll for delayed recording UI (default 2000). Set 0 to skip.
# VOICE_LATE_RECORDING_UI_MS=2000

# Max ms to wait for Instagram recording UI (blue bar / 0:xx) — used to derive per-gesture wait if VOICE_MIC_ATTEMPT_WAIT_MS unset
# VOICE_RECORDING_UI_TIMEOUT_MS=12000
# Ms to poll after each mic activation attempt (element.click, mouse down/up, etc.); default ~min(4000, TIMEOUT/3)
# VOICE_MIC_ATTEMPT_WAIT_MS=2400
# Stepped pointer + press-hold on mic (ms, 120–400). Tweak if desktop Web ignores instant clicks.
# VOICE_MIC_PRESS_HOLD_MS=210
# Long press on mic to *start* recording if a normal click never shows the recording UI (350–2500).
# VOICE_MIC_START_HOLD_MS=550

# Login: submit style = click (default), enter, or enterthenclick. If login often fails, try LOGIN_SUBMIT=enterthenclick
# LOGIN_SUBMIT=click
# Wait up to this many ms for redirect after submit (default 20000). Increase if login often needs retry.
# LOGIN_WAIT_MS=20000

# Path to CSV (default: leads.csv in project root)
# LEADS_CSV=leads.csv

# --- Per-Instagram proxy (Cold DM connect; optional Decodo auto-provision) ---
# Preferred (cost-safe): shared gate credentials mode. One Decodo username/password reused for all IG accounts with per-account sticky session ids.
# This mode does NOT call POST /v2/sub-users and avoids per-user Decodo billing.
# DECODO_SHARED_USERNAME=your_decodo_proxy_username
# DECODO_SHARED_PASSWORD=your_decodo_proxy_password
# Optional alias names if you prefer:
# DECODO_GATE_USERNAME=your_decodo_proxy_username
# DECODO_GATE_PASSWORD=your_decodo_proxy_password
# Optional: label only for provider_ref (defaults residential_proxies).
# DECODO_SHARED_SERVICE_TYPE=residential_proxies
#
# Legacy mode: Decodo Public API v2 auto-creates sub-users with your dashboard API key (may incur per-user billing).
# Create/copy a key under Dashboard → Settings → API (see https://help.decodo.com/reference/public-api-key-authentication ).
# DECODO_API_KEY=paste_public_api_key
# Alias: DECODO_API_TOKEN=
# Optional: full Authorization header value if your key must not use Bearer (overrides DECODO_API_KEY).
# DECODO_AUTHORIZATION=
# How to send the key: raw (default — key only in Authorization), bearer, or token.
# DECODO_AUTH_SCHEME=raw
# When using API-key legacy mode, the VPS creates a Decodo sub-user per (client, IG handle) on first connect and stores the URL in Supabase (`cold_dm_proxy_assignments`). Reconnects reuse the same proxy; deleting the IG session row does not delete the assignment. Generated sub-user passwords meet Decodo rules: ≥12 chars, upper+lower+digit, and one symbol from _ ~ + = only (other symbols → generic 400).
# Billing is by Decodo plan (traffic GB and/or ports)—not “number of URL strings.” Monitor usage in the Decodo dashboard.
# Optional API host (default https://api.decodo.com).
# DECODO_API_BASE=https://api.decodo.com
# HTTP proxy gate for Puppeteer (sub-user credentials are embedded in the stored proxy URL).
# DECODO_GATE_HOST=gate.decodo.com
# DECODO_GATE_PORT=10001
# Gate username format: Decodo docs require `user-` + sub-user name for residential (default). Set to empty to disable if your endpoint uses raw sub-user only.
# DECODO_GATE_USERNAME_PREFIX=user-
# Sticky session: same egress IP for many requests (helps Instagram trust). Residential only unless you know your plan supports it. Set to 0 to disable.
# DECODO_STICKY_SESSION=1
# Sticky session duration (minutes). Default 60; minimum enforced 30 for auto-provision (Decodo allows 1–1440).
# DECODO_STICKY_SESSION_DURATION_MINUTES=60
# Residential exit country (ISO 3166-1 alpha-2). Default is Germany (`de`) when unset.
# Set to force geo (e.g. us, gb, de). Default is de. Disable pinning explicitly: none
# DECODO_GATE_COUNTRY=de
# DECODO_GATE_COUNTRY=none
# Optional city (requires country). Tightens UK exit, e.g. london — Decodo uses underscores for multi-word cities.
# DECODO_GATE_CITY=london
# Sub-user service_type for POST /v2/sub-users. If unset, we use service_type from GET /v2/subscriptions (avoids generic 400 when plan type does not match).
# DECODO_SUBUSER_SERVICE_TYPE=residential_proxies
# DECODO_SUBUSER_SERVICE_TYPE=shared_proxies
# If unset, after a failed create we retry once with the other service_type (residential ↔ shared). Set to 0 to disable.
# DECODO_TRY_ALT_SERVICE_TYPE=
# Username shape: compact (default, one letter + hex, no underscore) or legacy (skm_ + hex).
# Optional 1–3 letter prefix for compact (default u). Change if Decodo rejects the default shape.
# DECODO_SUBUSER_USERNAME_PREFIX=u
# Max total username length for compact (6–64). Default 32 — long usernames often get generic 400 from Decodo.
# DECODO_SUBUSER_USERNAME_MAX_LEN=32
# DECODO_SUBUSER_USERNAME_MODE=compact
# Debug: log POST attempts (username + lengths), subscription snapshot, and full Decodo HTTP error responses (status + body; no request passwords).
# DECODO_DEBUG=
# Login debug screenshots: writes PNGs to logs/login-debug on VPS (before submit, checkpoints, and failures).
# LOGIN_DEBUG_SCREENSHOTS=1
# Connect hardening: align browser locale/timezone with proxy geography during one-time connect.
# CONNECT_ACCEPT_LANGUAGE=de-DE,de;q=0.9,en;q=0.8
# CONNECT_TIMEZONE_ID=Europe/Berlin
# CONNECT_CHROME_LANG=de-DE
# Instagram /terms/unblock only: full-page PNG + log of visible button text/aria-label (same logs/login-debug folder).
# TERMS_UNBLOCK_DEBUG_SCREENSHOTS=1
# When DM /direct/new search cannot click a result: full-page PNG (logs/login-debug). Snippet/meta always logged on failure.
# DM_SEARCH_DEBUG_SCREENSHOTS=1
# Optional ms to wait before reading thread display name from DOM (lazy header). Try 300–800 if extraction often misses.
# NAME_EXTRACTION_SETTLE_MS=0
# Verbose JSON for display-name extraction (step3b / step5). NAME_EXTRACTION_DEBUG=1
# Worker: log each cold_dm_sent_messages insert + cold_dm_daily_stats CAS (timezone, campaign_id, message_group_*).
# COLD_DM_METRICS_DEBUG=1
# Worker + queue: log claim attempts/fallback ordering and claimed jobs (worker_id/client_id/campaign_id).
# COLD_DM_CONCURRENCY_DEBUG=1
# Safety timeout for claim_cold_dm_send_job RPC before fallback path is used (prevents startup stalls).
# CLAIM_SEND_JOB_RPC_TIMEOUT_MS=12000
# Set to 1 or true to skip auto-provisioning (connect runs without a proxy unless an assignment already exists).
# DECODO_DISABLE_AUTO=

# Required for /api/* (except /api/health and /api/internal/scale-send-workers). The bundled dashboard gets an HttpOnly cookie on GET / from this value — nothing to paste in the UI. Other apps send Authorization: Bearer or x-api-key. Also used for cold-dm-on-send Edge Function after each successful send.
# COLD_DM_API_KEY=your-long-random-secret
# Optional: set to 1 only if the browser uses HTTPS to this server (otherwise the auth cookie may not stick).
# COLD_DM_COOKIE_SECURE=1

# --- PM2 send worker cluster (ig-dm-send) ---
# Initial instance count when using ecosystem.config.cjs (before any dynamic scale).
# SEND_WORKER_INSTANCES=4
# Fallbacks if SEND_WORKER_INSTANCES unset: COLD_DM_MAX_CONCURRENT_SENDERS or COLD_DM_ACTIVE_SESSION_COUNT
# Bounds for Supabase-driven scale (pause=0 clients vs sessions on those clients); see getRecommendedSendWorkerInstanceCount.
# SEND_WORKER_MIN=1
# SEND_WORKER_MAX=64
# Optional override if the PM2 app name is not ig-dm-send.
# SEND_WORKER_PM2_NAME=ig-dm-send
# After PM2 stop/crash, reclaim IG session lease if no heartbeat for this many seconds (default 120). Avoids stuck waiting_for_session.
# INSTAGRAM_SESSION_LEASE_STALE_SEC=120
# Sync pipeline: UUID .in(...) chunk size for lead lookup while building send jobs (default 80).
# Lower this if your stack still reports HeadersOverflowError / UND_ERR_HEADERS_OVERFLOW.
# SEND_SYNC_LEAD_ID_CHUNK=80
# Secret for POST /api/internal/scale-send-workers (header x-scale-send-workers-secret). Or run: npm run scale:send-workers
# SCALE_SEND_WORKERS_SECRET=
# Auto: dashboard (server.js) scales ig-dm-send on a timer + ~8s after any Start. Default ON when Supabase is configured.
# Set to 0 on a dev machine without PM2 to avoid noisy attempts.
# SCALE_SEND_WORKERS_AUTO=0
# SCALE_SEND_WORKERS_AUTO_INTERVAL_MINUTES=5

# --- Scraper only (Python instagrapi worker). Sending is always Puppeteer (browser). ---
# Proxy for scraper (e.g. Webshare). Format: http://user:pass@host:port
# SCRAPER_PROXY_URL=http://user:pass@1.2.3.4:6754

# Safety: conservative defaults to avoid detection. All times in seconds unless noted.
# Delay between every API request (instagrapi internal).
# SCRAPER_DELAY_MIN=5
# SCRAPER_DELAY_MAX=15
# Warm-up: pause before first request (avoids burst-on-connect).
# SCRAPER_WARMUP_MIN=45
# SCRAPER_WARMUP_MAX=90
# Before first API call and between major calls (e.g. user_id then user_followers).
# SCRAPER_DELAY_BEFORE_FIRST_MIN=10
# SCRAPER_DELAY_BEFORE_FIRST_MAX=25
# SCRAPER_DELAY_BETWEEN_CALLS_MIN=12
# SCRAPER_DELAY_BETWEEN_CALLS_MAX=28
# Every 50 items: batch pause.
# SCRAPER_DELAY_BATCH_MIN=15
# SCRAPER_DELAY_BATCH_MAX=35
# Per-item pause in the loop.
# SCRAPER_DELAY_PER_ITEM_MIN=0.8
# SCRAPER_DELAY_PER_ITEM_MAX=2.2
# Chunk cooldown: every N items, long pause (mimics human break). N and seconds.
# SCRAPER_CHUNK_COOLDOWN_EVERY=200
# SCRAPER_CHUNK_COOLDOWN_MIN=120
# SCRAPER_CHUNK_COOLDOWN_MAX=300
# Jitter: every N items, extra random delay (breaks patterns). N and seconds.
# SCRAPER_JITTER_EVERY=500
# SCRAPER_JITTER_EXTRA_MIN=15
# SCRAPER_JITTER_EXTRA_MAX=45
# Skip session validation (one fewer request at start). Use if validation causes issues.
# SKIP_SESSION_VALIDATION=0

# --- Admin Cold Outreach Lab (isolated; does not use cold_dm_* campaign tables) ---
# Shared secret: set the same value on the VPS and in Supabase Edge secret ADMIN_LAB_SECRET (cold-dm-vps-proxy).
# ADMIN_LAB_SECRET=generate_a_long_random_string
# Decodo mobile proxy (HTTP). Never commit real credentials — use rotated values from the provider dashboard.
# ADMIN_LAB_DECODO_PROXY_URL=http://DECODO_USERNAME:DECODO_PASSWORD@gate.decodo.com:10001
# GraphQL doc_id for the followers edge (from DevTools → Network → graphql/query). Refresh every 2–4 weeks when IG changes queries.
# ADMIN_LAB_IG_DOC_ID_FOLLOWERS=
# Optional: override path for lab sender cookie JSON (default: admin_lab/.sessions/sender.json under this repo).
# ADMIN_LAB_SESSION_PATH=
# Optional: Python binary for follower scrape (default: python3).
# ADMIN_LAB_PYTHON=python3
# Optional: checkpoint interval for CSV writes in ig_public_followers_scrape.py (default 50).
# ADMIN_LAB_CHECKPOINT_EVERY=50
# Optional: GraphQL page size (default 40; keep small to save proxy bandwidth).
# ADMIN_LAB_GRAPHQL_FIRST=40
# Scrape mode: graphql (default), api_v1 (cookie-backed), or auto (try graphql then api_v1).
# ADMIN_LAB_SCRAPE_MODE=auto
# Optional api_v1 page size (default 24, max 50).
# ADMIN_LAB_API_V1_COUNT=24
# Optional explicit Cookie header for api_v1 mode. If unset, scraper tries admin_lab sender session cookies.
# ADMIN_LAB_IG_COOKIE_HEADER=

# Username → user id cache (admin_lab/.cache/user_ids.json): TTL in seconds (default 30 days).
# ADMIN_LAB_USER_ID_CACHE_TTL_SEC=2592000
# Comma-separated seconds to wait after each HTTP 429 on web_profile_info (resolver). Default: 60,180,600.
# ADMIN_LAB_WEB_PROFILE_429_BACKOFF_SEC=60,180,600
# Comma-separated seconds after GraphQL follower query 429s. Default: 45,120,300.
# ADMIN_LAB_GRAPHQL_429_BACKOFF_SEC=45,120,300
# If 1/true, follower scrape will not call web_profile_info inline — use POST /api/admin-lab/scrape/resolve or pass user id.
# ADMIN_LAB_SCRAPE_REQUIRE_CACHED_USER_ID=0
# Max time (ms) for the VPS resolve subprocess (Edge allows 20m). Default 1200000.
# ADMIN_LAB_RESOLVE_HTTP_TIMEOUT_MS=1200000

# --- ig-dm-bot / send worker: keep debug OFF in production ---
# Remove or leave unset (no screenshots, less log noise):
#   LOGIN_DEBUG=0          LOGIN_DEBUG_SCREENSHOTS=0
#   TERMS_UNBLOCK_DEBUG_SCREENSHOTS=0   DM_SEARCH_DEBUG_SCREENSHOTS=0
#   DECODO_DEBUG=0         SCRAPER_DEBUG=0
#   FOLLOW_UP_DEBUG_SCREENSHOTS=false
# One full-page PNG right after composer focus, immediately BEFORE message text is typed (logs/login-debug). Does not enable any other screenshots.
# DM_COMPOSE_TYPING_SCREENSHOT=1
# One full-page PNG when compose is missing/no_compose (logs/login-debug). Defaults ON if DM_COMPOSE_TYPING_SCREENSHOT=1.
# DM_COMPOSE_FAILURE_SCREENSHOT=1
# One full-page PNG right after pressing Enter send (logs/login-debug). Useful to debug "sent click happened but UI looked wrong".
# DM_COMPOSE_POST_SEND_SCREENSHOT=1

# --- Typical VPS .env skeleton (adjust to your setup; do not commit real secrets) ---
# Supabase (worker): SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
# Auth: COLD_DM_API_KEY
# Proxy (shared Decodo): DECODO_SHARED_USERNAME, DECODO_SHARED_PASSWORD, optional DECODO_GATE_COUNTRY / DECODO_GATE_CITY / DECODO_STICKY_SESSION / DECODO_DISABLE_AUTO
# Browser: HEADLESS_MODE, DISPLAY (if Xvfb), DESKTOP_VIEWPORT_*
# Voice (if campaigns use voice): VOICE_USE_NULL_SINK, PULSE_SERVER, XDG_RUNTIME_DIR, VOICE_NOTE_* sink names
# Sending limits: DAILY_SEND_LIMIT, MIN_DELAY_MINUTES, MAX_DELAY_MINUTES, MAX_SENDS_PER_HOUR
# Optional: SCRAPER_PROXY_URL / SCRAPE_* only if you run scraper on same host; ADMIN_LAB_* only for admin lab
# Optional: SUPABASE_DB_URL only if something in your stack needs direct Postgres (prefer service role + REST for worker)
