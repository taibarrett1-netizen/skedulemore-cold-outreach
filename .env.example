# Instagram account (use a test account first)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Safety limits
DAILY_SEND_LIMIT=100
MIN_DELAY_MINUTES=5
MAX_DELAY_MINUTES=30
MAX_SENDS_PER_HOUR=20

# Run browser in background (true) or visible (false)
HEADLESS_MODE=true

# Linux VPS: when HEADLESS_MODE=false, Chromium needs a display (e.g. Xvfb). Example: DISPLAY=:99
# DISPLAY=:99

# Desktop Chrome viewport for Instagram Web (voice + DM layout). Default 1920x1200.
# Xvfb must be at least viewport + window padding (see DESKTOP_WINDOW_PAD_*), e.g. 1920x1440x24.
# DESKTOP_VIEWPORT_WIDTH=1920
# DESKTOP_VIEWPORT_HEIGHT=1200
# Extra pixels on --window-size beyond viewport (browser tabs/toolbar). Default +0,+220.
# DESKTOP_WINDOW_PAD_X=0
# DESKTOP_WINDOW_PAD_Y=280
# Headed Chromium top-left on X11 (stops WM cascade placing window off top). Format: x,y
# CHROME_WINDOW_POSITION=0,0

# Voice notes: pipe-source (preferred) or null-sink. PM2 needs PULSE_SERVER — add to .env:
# PULSE_SERVER=unix:/run/user/0/pulse/native
# XDG_RUNTIME_DIR=/run/user/0
# If module-pipe-source fails ("Module initialization failed"), set VOICE_USE_NULL_SINK=true to use null-sink+monitor instead
# VOICE_USE_NULL_SINK=true

# Slow down Puppeteer for debugging (ms). Useful with VNC. Example: 80
# PUPPETEER_SLOW_MO_MS=80

# Debug: POST /api/debug/follow-up/browser — auto-close that Chromium after N ms (else stays until PM2 restart)
# FOLLOW_UP_DEBUG_BROWSER_MS=1800000

# After voice Send, wait until thread DOM updates (audio/list rows). Set false only if you see false negatives.
# VOICE_NOTE_STRICT_VERIFY=true

# Chrome fake-mic voice: pad WAV (seconds), recording lag vs file length, loop trim (tune if clip cuts off or loops at end)
# VOICE_FAKE_MIC_PAD_START_SEC=0.12
# VOICE_FAKE_MIC_PAD_END_SEC=0.22
# VOICE_FAKE_MIC_RECORDING_LAG_MS=680
# VOICE_FAKE_MIC_HOLD_JITTER_MS=80
# VOICE_FAKE_MIC_LOOP_TRIM_MS=180

# Headless: screenshots show recording UI but heuristics fail — still run ffmpeg + hold + Send after mic attempts.
# VOICE_ASSUME_RECORDING_AFTER_MIC=true
# Polls required to confirm recording UI (default 2). Try 1 if detection is too strict.
# VOICE_RECORDING_UI_CONFIRM_STREAK=1
# Desktop mic: run only one method (exact name). See VOICE_DESKTOP_MIC_METHOD_NAMES in instagram-voice-note.js exports.
# VOICE_DESKTOP_MIC_METHOD=mouse_hold_to_start_recording
# Send click: nudge X px right before Puppeteer mouse click (default 14). Set 0 for no offset.
# VOICE_SEND_CLICK_NUDGE_X=14
# Ms to wait after last mic attempt, then one poll for delayed recording UI (default 2000). Set 0 to skip.
# VOICE_LATE_RECORDING_UI_MS=2000

# Max ms to wait for Instagram recording UI (blue bar / 0:xx) — used to derive per-gesture wait if VOICE_MIC_ATTEMPT_WAIT_MS unset
# VOICE_RECORDING_UI_TIMEOUT_MS=12000
# Ms to poll after each mic activation attempt (element.click, mouse down/up, etc.); default ~min(4000, TIMEOUT/3)
# VOICE_MIC_ATTEMPT_WAIT_MS=2400
# Stepped pointer + press-hold on mic (ms, 120–400). Tweak if desktop Web ignores instant clicks.
# VOICE_MIC_PRESS_HOLD_MS=210
# Long press on mic to *start* recording if a normal click never shows the recording UI (350–2500).
# VOICE_MIC_START_HOLD_MS=550

# Login: submit style = click (default), enter, or enterthenclick. If login often fails, try LOGIN_SUBMIT=enterthenclick
# LOGIN_SUBMIT=click
# Wait up to this many ms for redirect after submit (default 20000). Increase if login often needs retry.
# LOGIN_WAIT_MS=20000

# Path to CSV (default: leads.csv in project root)
# LEADS_CSV=leads.csv

# Optional: require this key for /api/* when calling from another app (e.g. Lovable). Also used to call cold-dm-on-send Edge Function after each successful send. Leave unset for local dashboard only.
# COLD_DM_API_KEY=your-long-random-secret

# --- Scraper only (Python instagrapi worker). Sending is always Puppeteer (browser). ---
# Proxy for scraper (e.g. Webshare). Format: http://user:pass@host:port
# SCRAPER_PROXY_URL=http://user:pass@1.2.3.4:6754

# Safety: conservative defaults to avoid detection. All times in seconds unless noted.
# Delay between every API request (instagrapi internal).
# SCRAPER_DELAY_MIN=5
# SCRAPER_DELAY_MAX=15
# Warm-up: pause before first request (avoids burst-on-connect).
# SCRAPER_WARMUP_MIN=45
# SCRAPER_WARMUP_MAX=90
# Before first API call and between major calls (e.g. user_id then user_followers).
# SCRAPER_DELAY_BEFORE_FIRST_MIN=10
# SCRAPER_DELAY_BEFORE_FIRST_MAX=25
# SCRAPER_DELAY_BETWEEN_CALLS_MIN=12
# SCRAPER_DELAY_BETWEEN_CALLS_MAX=28
# Every 50 items: batch pause.
# SCRAPER_DELAY_BATCH_MIN=15
# SCRAPER_DELAY_BATCH_MAX=35
# Per-item pause in the loop.
# SCRAPER_DELAY_PER_ITEM_MIN=0.8
# SCRAPER_DELAY_PER_ITEM_MAX=2.2
# Chunk cooldown: every N items, long pause (mimics human break). N and seconds.
# SCRAPER_CHUNK_COOLDOWN_EVERY=200
# SCRAPER_CHUNK_COOLDOWN_MIN=120
# SCRAPER_CHUNK_COOLDOWN_MAX=300
# Jitter: every N items, extra random delay (breaks patterns). N and seconds.
# SCRAPER_JITTER_EVERY=500
# SCRAPER_JITTER_EXTRA_MIN=15
# SCRAPER_JITTER_EXTRA_MAX=45
# Skip session validation (one fewer request at start). Use if validation causes issues.
# SKIP_SESSION_VALIDATION=0
